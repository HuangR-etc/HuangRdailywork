# ============================================================
# 2. Common par settings for combined figures
#    (basically same style as your single-panel figures)
# ============================================================
set_combined_par <- function() {
par(
mar = c(3.8, 4.0, 1.8, 0.8),
mgp = c(2.0, 0.65, 0),
tcl = -0.25,
cex = 0.95
)
}
